#!/bin/bash
# Ralph Wiggum Loop - main executable
#
# Usage:
#   ralph plan [max_iterations]
#   ralph build [max_iterations]
#   ralph align-specs [max_iterations]
#   ralph prompt <file> [max_iterations]
#   ralph update
#   ralph sandbox <setup|up|stop|reset|shell|status>

set -euo pipefail

# ---------------------------------------------------------------------------
# Self-relative path resolution
# ---------------------------------------------------------------------------
RALPH_DIR="$(dirname "$(readlink -f "$0")")"
RALPH_HOME="$(realpath --relative-to=. "$RALPH_DIR")"

# ---------------------------------------------------------------------------
# Defaults (may be overridden by config)
# ---------------------------------------------------------------------------
DEFAULT_MAX_ITERATIONS=10
MAX_RETRIES=3
SPECS_DIR="specs"

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------
MODE=""
MAX_ITERATIONS=""
PROMPT_FILE=""
SANDBOX_ARGS=()
PROCESS_FLAG=0
HELP_TOPIC=""

usage() {
    cat <<EOF
Usage: ralph <mode> [max_iterations]

Modes:
  help                                 List available help topics
  help   [topic]                       Show operational guidance on a topic
  plan   [max_iterations]              Run gap-driven plan mode iterations
  plan   --process [max_iterations]    Run process plan mode iterations
  build  [max_iterations]              Run build mode iterations
  align-specs [max_iterations]         Update target-state specs after process migration
  prompt <file> [max_iterations]       Run an ad-hoc prompt from file in the loop
  update                               Update ralph to the latest upstream version
  sandbox setup [--force]              Generate sandbox files by prompting the agent
  sandbox up                           Start the sandbox container
  sandbox stop                         Stop the sandbox container
  sandbox reset [--all]                Re-clone codebase (--all: delete all volumes)
  sandbox shell                        Open a bash shell inside the container
  sandbox status                       Show sandbox container status

Examples:
  ralph help
  ralph help sandbox
  ralph plan
  ralph build 20
  ralph prompt prompts/my-prompt.md
EOF
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        plan|build|align-specs|prompt|update|sandbox|help)
            if [[ "$MODE" == "help" ]]; then
                HELP_TOPIC="$1"
            else
                MODE="$1"
            fi
            shift
            ;;
        --process)
            PROCESS_FLAG=1
            shift
            continue
            ;;
        --help|-h)
            usage
            exit 0
            ;;
        *)
            if [[ -z "$MODE" ]]; then
                echo "Error: unknown option or mode: $1" >&2
                usage >&2
                exit 1
            fi
            if [[ "$MODE" == "help" ]]; then
                HELP_TOPIC="$1"
            elif [[ "$MODE" == "sandbox" ]]; then
                SANDBOX_ARGS+=("$1")
            elif [[ "$MODE" == "prompt" && -z "$PROMPT_FILE" ]]; then
                PROMPT_FILE="$1"
            else
                MAX_ITERATIONS="$1"
            fi
            shift
            ;;
    esac
done

if [[ -z "$MODE" ]]; then
    usage
    exit 1
fi

if [[ "$PROCESS_FLAG" -eq 1 && "$MODE" != "plan" ]]; then
    echo "Error: --process is only valid with 'ralph plan'." >&2
    exit 1
fi

# ---------------------------------------------------------------------------
# Load configuration
# ---------------------------------------------------------------------------
CONFIG_FILE="$RALPH_DIR/config"

if [[ ! -f "$CONFIG_FILE" ]]; then
    echo "Error: config file not found: $CONFIG_FILE" >&2
    exit 1
fi

# shellcheck source=/dev/null
source "$CONFIG_FILE"

: "${MAX_ITERATIONS:=${DEFAULT_MAX_ITERATIONS:-10}}"

# ---------------------------------------------------------------------------
# Load sandbox module
# ---------------------------------------------------------------------------
# shellcheck source=/dev/null
source "$RALPH_DIR/lib/sandbox.sh"

# ---------------------------------------------------------------------------
# Load agent script
# ---------------------------------------------------------------------------
if [[ "$MODE" != "update" && "$MODE" != "sandbox" && "$MODE" != "help" ]]; then
    AGENT_SCRIPT="$RALPH_DIR/agents/${AGENT}.sh"
    if [[ ! -f "$AGENT_SCRIPT" ]]; then
        echo "Error: agent script not found: $AGENT_SCRIPT" >&2
        exit 1
    fi
    # shellcheck source=/dev/null
    source "$AGENT_SCRIPT"
fi

# ---------------------------------------------------------------------------
# Prerequisite validation
# ---------------------------------------------------------------------------
validate_prerequisites() {
    [[ "$MODE" == "sandbox" || "$MODE" == "help" ]] && return

    if [[ ! -d ".git" ]]; then
        echo "Error: not a git repository (no .git directory found)" >&2
        exit 1
    fi

    [[ "$MODE" == "update" ]] && return

    if ! command -v "$AGENT_CLI" &>/dev/null; then
        echo "Error: agent CLI not found in PATH: $AGENT_CLI" >&2
        exit 1
    fi

    if [[ ! -d "$SPECS_DIR" ]]; then
        echo "Error: specs directory not found: $SPECS_DIR" >&2
        exit 1
    fi
}

# ---------------------------------------------------------------------------
# Session log initialization
# ---------------------------------------------------------------------------
init_session_log() {
    local log_dir="$RALPH_DIR/logs"
    mkdir -p "$log_dir"
    SESSION_LOG="$log_dir/session-$(date +%Y%m%d-%H%M%S)-${MODE}.log"
    touch "$SESSION_LOG"
}

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
log() {
    echo "$*" | tee -a "$SESSION_LOG"
}

# ---------------------------------------------------------------------------
# Template variable substitution
# ---------------------------------------------------------------------------
prepare_prompt() {
    local template_file="$1"
    local output_file="$2"
    export MODE SPECS_DIR RALPH_HOME
    export PLAN_HEADER TASK_OVERVIEW SELECTED_TASK ADJACENT_CONTEXT
    envsubst < "$template_file" > "$output_file"
}

# ---------------------------------------------------------------------------
# Signal detection
# ---------------------------------------------------------------------------
check_signals() {
    local output_file="$1"
    local response
    response=$(agent_extract_response "$output_file")
    if echo "$response" | grep -qF '<promise>COMPLETE</promise>'; then return 2; fi
    if echo "$response" | grep -qF '<promise>REPLAN</promise>'; then return 3; fi
    return 0
}

# ---------------------------------------------------------------------------
# Run a single iteration (with retries)
# Returns:
#   0 - success, continue looping
#   1 - retries exhausted
#   2 - completion signal detected
#   3 - replan signal detected
# ---------------------------------------------------------------------------
run_iteration() {
    local iteration="$1"
    local prompt_template="$2"
    local retry=0

    while [[ $retry -le $MAX_RETRIES ]]; do
        local iter_start
        iter_start=$(date +%s)

        log "================================================================================"
        log "ITERATION ${iteration}  $(date '+%Y-%m-%d %H:%M:%S')"
        log "mode: ${MODE}  prompt: ${prompt_template}"
        log "================================================================================"

        local tmp_prompt
        tmp_prompt=$(mktemp)
        prepare_prompt "$prompt_template" "$tmp_prompt"

        type agent_pre_iteration &>/dev/null && agent_pre_iteration

        local agent_rc=0
        agent_invoke "$tmp_prompt" \
            | tee "$RALPH_DIR/last_agent_output" \
            | agent_format_display \
            | tee -a "$SESSION_LOG" \
            || agent_rc=$?

        rm -f "$tmp_prompt"

        # Detect empty response (budget exhaustion, auth failure, transient error)
        if [[ $agent_rc -eq 0 ]]; then
            local response
            response=$(agent_extract_response "$RALPH_DIR/last_agent_output")
            if [[ -z "$response" ]]; then
                log "⚠ Agent produced no response — possible budget exhaustion or transient failure"
                agent_rc=1
            fi
        fi

        log "================================================================================"
        local duration=$(( $(date +%s) - iter_start ))
        log "ITERATION ${iteration} DONE in ${duration}s ----"

        type agent_post_iteration &>/dev/null && agent_post_iteration
        log "================================================================================"

        if [[ $agent_rc -ne 0 ]]; then
            retry=$(( retry + 1 ))
            if [[ $retry -le $MAX_RETRIES ]]; then
                log "Agent failure, retry ${retry}/${MAX_RETRIES}..."
                continue
            fi
            return 1
        fi

        local signal_rc=0
        check_signals "$RALPH_DIR/last_agent_output" || signal_rc=$?
        return $signal_rc
    done

    return 1
}

# ---------------------------------------------------------------------------
# Main loop
# ---------------------------------------------------------------------------
run_loop() {
    local prompt_template="$1"
    local session_start iteration=0 success=0 failures=0
    local exit_reason="max iterations reached" exit_code=0
    local context_min="" context_max="" context_sum=0 context_count=0 context_window=""
    session_start=$(date +%s)

    while [[ $iteration -lt $MAX_ITERATIONS ]]; do
        iteration=$(( iteration + 1 ))
        _ITER_CONTEXT_USED="" _ITER_CONTEXT_MAX="" _ITER_CONTEXT_PCT=""

        local rc=0
        run_iteration "$iteration" "$prompt_template" || rc=$?

        if [[ -n "${_ITER_CONTEXT_PCT:-}" ]]; then
            context_count=$(( context_count + 1 ))
            context_sum=$(( context_sum + _ITER_CONTEXT_PCT ))
            context_window="${_ITER_CONTEXT_MAX}"
            if [[ -z "$context_min" || "$_ITER_CONTEXT_PCT" -lt "$context_min" ]]; then
                context_min=$_ITER_CONTEXT_PCT
            fi
            if [[ -z "$context_max" || "$_ITER_CONTEXT_PCT" -gt "$context_max" ]]; then
                context_max=$_ITER_CONTEXT_PCT
            fi
        fi

        case $rc in
            0) success=$(( success + 1 )) ;;
            2) success=$(( success + 1 )); exit_reason="completion signal"; break ;;
            3) success=$(( success + 1 )); exit_reason="replan signal"; exit_code=3
               local plan_cmd
               plan_cmd=$(grep -m1 '^Plan Command:' "${RALPH_HOME}/implementation_plan.md" 2>/dev/null \
                   | sed 's/^Plan Command:[[:space:]]*//' || true)
               [[ -z "$plan_cmd" ]] && plan_cmd="ralph plan"
               log "Agent requested re-planning. Run '${plan_cmd}' to regenerate the implementation plan."
               break ;;
            *) failures=$(( failures + 1 )); exit_reason="agent failure exceeded retries"; exit_code=4
               break ;;
        esac
    done

    log "================================================================================"
    log "SESSION SUMMARY"
    log "================================================================================"
    log "Iterations: ${iteration}  Successful: ${success}  Failed: ${failures}"
    log "Duration: $(( $(date +%s) - session_start ))s"
    if [[ "$context_count" -gt 0 ]]; then
        local context_avg
        context_avg=$(( context_sum / context_count ))
        log "Context: min ${context_min}% / avg ${context_avg}% / max ${context_max}%  (window: ${context_window} tokens)"
    fi
    log "Exit: ${exit_reason} (code ${exit_code})"
    log "================================================================================"

    if [[ "$MODE" == "build" && "$exit_reason" == "completion signal" ]]; then
        plan_type=$(grep -m1 '^Plan Type:' "$RALPH_HOME/implementation_plan.md" 2>/dev/null \
            | sed 's/^Plan Type:[[:space:]]*//' || true)
        if [[ "$plan_type" == "process" ]]; then
            log ""
            log "╔══════════════════════════════════════════════════════════════════════════════════╗"
            log "║  Process-plan build complete. Target-state specs may need updating.            ║"
            log "║  Run: ralph align-specs                                                       ║"
            log "╚══════════════════════════════════════════════════════════════════════════════════╝"
        fi
    fi

    exit "$exit_code"
}

# ---------------------------------------------------------------------------
# Help system
# ---------------------------------------------------------------------------
ralph_help() {
    local topic="${1:-}"
    local help_dir="$RALPH_DIR/lib/help"
    if [[ -z "$topic" ]]; then
        cat "$help_dir/index.txt"
    elif [[ -f "$help_dir/${topic}.txt" ]]; then
        cat "$help_dir/${topic}.txt"
    else
        echo "Unknown help topic: $topic" >&2; echo
        cat "$help_dir/index.txt"
    fi
}

# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------
validate_prerequisites

if [[ "$MODE" == "help" ]]; then
    ralph_help "$HELP_TOPIC"
    exit 0
fi

case "$MODE" in
    plan)
        if [[ "$PROCESS_FLAG" -eq 1 ]]; then
            if [[ -z "${PROCESS_DIR:-}" ]]; then
                echo "Error: No PROCESS_DIR configured. Set PROCESS_DIR in config." >&2
                exit 1
            fi
            if [[ ! -d "$PROCESS_DIR" ]]; then
                echo "Error: PROCESS_DIR '${PROCESS_DIR}' not found." >&2
                exit 1
            fi
            if ! ls "$PROCESS_DIR"/*.md &>/dev/null; then
                echo "Error: No process specs found in '${PROCESS_DIR}/'." >&2
                exit 1
            fi
            export PROCESS_DIR

            SPEC_BYTES=$(cat "$PROCESS_DIR"/*.md 2>/dev/null | wc -c)
            SPEC_COUNT=$(find "$PROCESS_DIR" -maxdepth 1 -name '*.md' | wc -l)
            SPEC_KB=$(( SPEC_BYTES / 1024 ))
            if [[ "$SPEC_KB" -lt 50 && "$SPEC_COUNT" -lt 5 ]]; then
                SPEC_VOLUME_HINT="Total process spec volume: ${SPEC_COUNT} files, ~${SPEC_KB} KB. You can likely complete planning in one iteration."
            else
                SPEC_VOLUME_HINT="Total process spec volume: ${SPEC_COUNT} files, ~${SPEC_KB} KB. This exceeds single-iteration capacity. Use the decomposition ledger and process one spec file per iteration."
            fi
            export SPEC_VOLUME_HINT

            PROMPT_TEMPLATE="$RALPH_DIR/prompts/plan-process.md"
        else
            PROMPT_TEMPLATE="$RALPH_DIR/prompts/plan.md"
        fi
        if [[ ! -f "$PROMPT_TEMPLATE" ]]; then
            echo "Error: plan prompt template not found: $PROMPT_TEMPLATE" >&2
            exit 1
        fi
        init_session_log
        run_loop "$PROMPT_TEMPLATE"
        ;;

    build)
        if [[ ! -f "$RALPH_DIR/implementation_plan.md" ]]; then
            echo "Implementation plan not found. Run 'ralph plan' first." >&2
            exit 2
        fi

        local plan_file="$RALPH_DIR/implementation_plan.md"
        local filter="$RALPH_DIR/lib/plan-filter.sh"

        # Extract plan type
        local plan_type_check
        plan_type_check=$(grep -m1 '^Plan Type:' "$plan_file" 2>/dev/null \
            | sed 's/^Plan Type:[[:space:]]*//' || true)

        # Extract plan header (everything above first ### Task)
        PLAN_HEADER=""
        if [[ -f "$filter" ]]; then
            PLAN_HEADER=$(bash "$filter" header "$plan_file" 2>/dev/null || true)
        fi
        export PLAN_HEADER

        # Generate smart task overview
        TASK_OVERVIEW=""
        if [[ -f "$filter" ]]; then
            local overview
            overview=$(bash "$filter" overview "$plan_file" 2>/dev/null || true)
            if [[ -n "$overview" ]]; then
                TASK_OVERVIEW="$overview"
            fi
        fi
        export TASK_OVERVIEW

        # For process plans: deterministic task selection
        SELECTED_TASK=""
        ADJACENT_CONTEXT=""
        if [[ "$plan_type_check" == "process" && -f "$filter" ]]; then
            local select_output
            select_output=$(bash "$filter" select "$plan_file" 2>/dev/null || true)
            if [[ -n "$select_output" && "$select_output" != "NO_ELIGIBLE_TASK" ]]; then
                SELECTED_TASK=$(echo "$select_output" | sed -n '/^---SELECTED_TASK---$/,/^---END_SELECTED_TASK---$/{ /^---.*---$/d; p; }')
                ADJACENT_CONTEXT=$(echo "$select_output" | sed -n '/^---ADJACENT_CONTEXT---$/,/^---END_ADJACENT_CONTEXT---$/{ /^---.*---$/d; p; }')
            fi
        fi
        export SELECTED_TASK ADJACENT_CONTEXT

        # Select prompt template by plan type
        if [[ "$plan_type_check" == "process" ]]; then
            PROMPT_TEMPLATE="$RALPH_DIR/prompts/build-process.md"
        else
            PROMPT_TEMPLATE="$RALPH_DIR/prompts/build.md"
        fi
        if [[ ! -f "$PROMPT_TEMPLATE" ]]; then
            echo "Error: build prompt template not found: $PROMPT_TEMPLATE" >&2
            exit 1
        fi
        init_session_log
        run_loop "$PROMPT_TEMPLATE"
        ;;

    align-specs)
        if [[ -z "${PROCESS_DIR:-}" ]]; then
            echo "Error: align-specs requires process specs. Set PROCESS_DIR in config." >&2
            exit 1
        fi
        local_plan="$RALPH_DIR/implementation_plan.md"
        if [[ ! -f "$local_plan" ]]; then
            echo "Error: align-specs requires a process-type implementation plan. Run 'ralph plan --process' and 'ralph build' first." >&2
            exit 1
        fi
        local_plan_type=$(grep -m1 '^Plan Type:' "$local_plan" 2>/dev/null \
            | sed 's/^Plan Type:[[:space:]]*//' || true)
        if [[ "$local_plan_type" != "process" ]]; then
            echo "Error: align-specs requires a process-type implementation plan. Run 'ralph plan --process' and 'ralph build' first." >&2
            exit 1
        fi
        if ! grep -q 'Status:.*complete' "$local_plan" 2>/dev/null; then
            echo "Error: align-specs requires completed build work. Run 'ralph build' first." >&2
            exit 1
        fi
        export PROCESS_DIR
        PROMPT_TEMPLATE="$RALPH_DIR/prompts/align-specs.md"
        if [[ ! -f "$PROMPT_TEMPLATE" ]]; then
            echo "Error: align-specs prompt template not found: $PROMPT_TEMPLATE" >&2
            exit 1
        fi
        init_session_log
        run_loop "$PROMPT_TEMPLATE"
        ;;

    prompt)
        if [[ -z "$PROMPT_FILE" ]]; then
            echo "Error: prompt mode requires a file argument" >&2
            usage >&2
            exit 1
        fi
        if [[ ! -f "$PROMPT_FILE" ]]; then
            echo "Error: prompt file not found: $PROMPT_FILE" >&2
            exit 1
        fi
        if ! grep -qF '<promise>COMPLETE</promise>' "$PROMPT_FILE"; then
            echo "Error: prompt file must contain <promise>COMPLETE</promise>" >&2
            exit 1
        fi
        init_session_log
        run_loop "$PROMPT_FILE"
        ;;

    update)
        echo "Fetching update script from GitHub..."
        curl -sSL https://raw.githubusercontent.com/mjeffe/ralph-loop/main/update.sh | bash
        ;;

    sandbox)
        if [[ "${SANDBOX:-}" == "1" ]]; then
            echo "Error: already inside the sandbox. Run ralph commands directly." >&2
            exit 1
        fi
        sandbox_sub="${SANDBOX_ARGS[0]:-}"
        sandbox_extra=()
        [[ ${#SANDBOX_ARGS[@]} -gt 1 ]] && sandbox_extra=("${SANDBOX_ARGS[@]:1}")
        case "$sandbox_sub" in
            setup)  sandbox_setup "${sandbox_extra[@]+"${sandbox_extra[@]}"}" ;;
            up)     sandbox_up "${sandbox_extra[@]+"${sandbox_extra[@]}"}" ;;
            stop)   sandbox_stop "${sandbox_extra[@]+"${sandbox_extra[@]}"}" ;;
            reset)  sandbox_reset "${sandbox_extra[@]+"${sandbox_extra[@]}"}" ;;
            shell)  sandbox_shell "${sandbox_extra[@]+"${sandbox_extra[@]}"}" ;;
            status) sandbox_status "${sandbox_extra[@]+"${sandbox_extra[@]}"}" ;;
            *)
                echo "Usage: ralph sandbox <setup|up|stop|reset|shell|status>"
                exit 1
                ;;
        esac
        ;;

    *)
        echo "Error: unknown mode: $MODE" >&2
        usage >&2
        exit 1
        ;;
esac
