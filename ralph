#!/bin/bash
# Ralph Wiggum Loop - main executable
#
# Usage:
#   ralph plan [max_iterations]
#   ralph build [max_iterations]
#   ralph align-specs [max_iterations]
#   ralph prompt <file> [max_iterations]
#   ralph update
#   ralph sandbox <setup|up|stop|reset|shell|status>

set -euo pipefail

# ---------------------------------------------------------------------------
# Self-relative path resolution
# ---------------------------------------------------------------------------
RALPH_DIR="$(dirname "$(readlink -f "$0")")"
RALPH_HOME="$(realpath --relative-to=. "$RALPH_DIR")"

# ---------------------------------------------------------------------------
# Defaults (may be overridden by config)
# ---------------------------------------------------------------------------
DEFAULT_MAX_ITERATIONS=10
MAX_RETRIES=3
SPECS_DIR="specs"

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------
MODE=""
MAX_ITERATIONS=""
PROMPT_FILE=""
SANDBOX_ARGS=()
PROCESS_FLAG=0
HELP_TOPIC=""

usage() {
    cat <<EOF
Usage: ralph <mode> [max_iterations]

Modes:
  help                                 List available help topics
  help   [topic]                       Show operational guidance on a topic
  plan   [max_iterations]              Run gap-driven plan mode iterations
  plan   --process [max_iterations]    Run process plan mode iterations
  build  [max_iterations]              Run build mode iterations
  align-specs [max_iterations]         Update target-state specs after process migration
  prompt <file> [max_iterations]       Run an ad-hoc prompt from file in the loop
  update                               Update ralph to the latest upstream version
  sandbox setup [--force]              Generate sandbox files by prompting the agent
  sandbox up                           Start the sandbox container
  sandbox stop                         Stop the sandbox container
  sandbox reset [--all]                Re-clone codebase (--all: delete all volumes)
  sandbox shell                        Open a bash shell inside the container
  sandbox status                       Show sandbox container status

Examples:
  ralph help
  ralph help sandbox
  ralph plan
  ralph build 20
  ralph prompt prompts/my-prompt.md
EOF
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        plan|build|align-specs|prompt|update|sandbox|help)
            if [[ "$MODE" == "help" ]]; then
                HELP_TOPIC="$1"
            else
                MODE="$1"
            fi
            shift
            ;;
        --process)
            PROCESS_FLAG=1
            shift
            continue
            ;;
        --help|-h)
            usage
            exit 0
            ;;
        *)
            if [[ -z "$MODE" ]]; then
                echo "Error: unknown option or mode: $1" >&2
                usage >&2
                exit 1
            fi
            if [[ "$MODE" == "help" ]]; then
                HELP_TOPIC="$1"
            elif [[ "$MODE" == "sandbox" ]]; then
                SANDBOX_ARGS+=("$1")
            elif [[ "$MODE" == "prompt" && -z "$PROMPT_FILE" ]]; then
                PROMPT_FILE="$1"
            else
                MAX_ITERATIONS="$1"
            fi
            shift
            ;;
    esac
done

if [[ -z "$MODE" ]]; then
    usage
    exit 1
fi

if [[ "$PROCESS_FLAG" -eq 1 && "$MODE" != "plan" ]]; then
    echo "Error: --process is only valid with 'ralph plan'." >&2
    exit 1
fi

# ---------------------------------------------------------------------------
# Load configuration
# ---------------------------------------------------------------------------
CONFIG_FILE="$RALPH_DIR/config"

if [[ ! -f "$CONFIG_FILE" ]]; then
    echo "Error: config file not found: $CONFIG_FILE" >&2
    exit 1
fi

# shellcheck source=/dev/null
source "$CONFIG_FILE"

: "${MAX_ITERATIONS:=${DEFAULT_MAX_ITERATIONS:-10}}"

# ---------------------------------------------------------------------------
# Load agent script
# ---------------------------------------------------------------------------
if [[ "$MODE" != "update" && "$MODE" != "sandbox" && "$MODE" != "help" ]]; then
    AGENT_SCRIPT="$RALPH_DIR/agents/${AGENT}.sh"
    if [[ ! -f "$AGENT_SCRIPT" ]]; then
        echo "Error: agent script not found: $AGENT_SCRIPT" >&2
        exit 1
    fi
    # shellcheck source=/dev/null
    source "$AGENT_SCRIPT"
fi

# ---------------------------------------------------------------------------
# Prerequisite validation
# ---------------------------------------------------------------------------
validate_prerequisites() {
    [[ "$MODE" == "sandbox" || "$MODE" == "help" ]] && return

    if [[ ! -d ".git" ]]; then
        echo "Error: not a git repository (no .git directory found)" >&2
        exit 1
    fi

    [[ "$MODE" == "update" ]] && return

    if ! command -v "$AGENT_CLI" &>/dev/null; then
        echo "Error: agent CLI not found in PATH: $AGENT_CLI" >&2
        exit 1
    fi

    if [[ ! -d "$SPECS_DIR" ]]; then
        echo "Error: specs directory not found: $SPECS_DIR" >&2
        exit 1
    fi
}

# ---------------------------------------------------------------------------
# Session log initialization
# ---------------------------------------------------------------------------
init_session_log() {
    local log_dir="$RALPH_DIR/logs"
    mkdir -p "$log_dir"
    SESSION_LOG="$log_dir/session-$(date +%Y%m%d-%H%M%S)-${MODE}.log"
    touch "$SESSION_LOG"
}

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
log() {
    echo "$*" | tee -a "$SESSION_LOG"
}

# ---------------------------------------------------------------------------
# Template variable substitution
# ---------------------------------------------------------------------------
prepare_prompt() {
    local template_file="$1"
    local output_file="$2"
    export MODE SPECS_DIR RALPH_HOME
    envsubst < "$template_file" > "$output_file"
}

# ---------------------------------------------------------------------------
# Signal detection
# ---------------------------------------------------------------------------
check_signals() {
    local output_file="$1"
    local response
    response=$(agent_extract_response "$output_file")
    if echo "$response" | grep -qF '<promise>COMPLETE</promise>'; then return 2; fi
    if echo "$response" | grep -qF '<promise>REPLAN</promise>'; then return 3; fi
    return 0
}

# ---------------------------------------------------------------------------
# Run a single iteration (with retries)
# Returns:
#   0 - success, continue looping
#   1 - retries exhausted
#   2 - completion signal detected
#   3 - replan signal detected
# ---------------------------------------------------------------------------
run_iteration() {
    local iteration="$1"
    local prompt_template="$2"
    local retry=0

    while [[ $retry -le $MAX_RETRIES ]]; do
        local iter_start
        iter_start=$(date +%s)

        log "================================================================================"
        log "ITERATION ${iteration}  $(date '+%Y-%m-%d %H:%M:%S')"
        log "mode: ${MODE}  prompt: ${prompt_template}"
        log "================================================================================"

        local tmp_prompt
        tmp_prompt=$(mktemp)
        prepare_prompt "$prompt_template" "$tmp_prompt"

        type agent_pre_iteration &>/dev/null && agent_pre_iteration

        local agent_rc=0
        agent_invoke "$tmp_prompt" \
            | tee "$RALPH_DIR/last_agent_output" \
            | agent_format_display \
            | tee -a "$SESSION_LOG" \
            || agent_rc=$?

        rm -f "$tmp_prompt"


        log "================================================================================"
        local duration=$(( $(date +%s) - iter_start ))
        log "ITERATION ${iteration} DONE in ${duration}s ----"

        type agent_post_iteration &>/dev/null && agent_post_iteration
        log "================================================================================"

        if [[ $agent_rc -ne 0 ]]; then
            retry=$(( retry + 1 ))
            if [[ $retry -le $MAX_RETRIES ]]; then
                log "Agent failure, retry ${retry}/${MAX_RETRIES}..."
                continue
            fi
            return 1
        fi

        local signal_rc=0
        check_signals "$RALPH_DIR/last_agent_output" || signal_rc=$?
        return $signal_rc
    done

    return 1
}

# ---------------------------------------------------------------------------
# Main loop
# ---------------------------------------------------------------------------
run_loop() {
    local prompt_template="$1"
    local session_start iteration=0 success=0 failures=0
    local exit_reason="max iterations reached" exit_code=0
    local context_min="" context_max="" context_sum=0 context_count=0 context_window=""
    session_start=$(date +%s)

    while [[ $iteration -lt $MAX_ITERATIONS ]]; do
        iteration=$(( iteration + 1 ))
        _ITER_CONTEXT_USED="" _ITER_CONTEXT_MAX="" _ITER_CONTEXT_PCT=""

        local rc=0
        run_iteration "$iteration" "$prompt_template" || rc=$?

        if [[ -n "${_ITER_CONTEXT_PCT:-}" ]]; then
            context_count=$(( context_count + 1 ))
            context_sum=$(( context_sum + _ITER_CONTEXT_PCT ))
            context_window="${_ITER_CONTEXT_MAX}"
            if [[ -z "$context_min" || "$_ITER_CONTEXT_PCT" -lt "$context_min" ]]; then
                context_min=$_ITER_CONTEXT_PCT
            fi
            if [[ -z "$context_max" || "$_ITER_CONTEXT_PCT" -gt "$context_max" ]]; then
                context_max=$_ITER_CONTEXT_PCT
            fi
        fi

        case $rc in
            0) success=$(( success + 1 )) ;;
            2) success=$(( success + 1 )); exit_reason="completion signal"; break ;;
            3) success=$(( success + 1 )); exit_reason="replan signal"; exit_code=3
               local plan_cmd
               plan_cmd=$(grep -m1 '^Plan Command:' "${RALPH_HOME}/implementation_plan.md" 2>/dev/null \
                   | sed 's/^Plan Command:[[:space:]]*//' || true)
               [[ -z "$plan_cmd" ]] && plan_cmd="ralph plan"
               log "Agent requested re-planning. Run '${plan_cmd}' to regenerate the implementation plan."
               break ;;
            *) failures=$(( failures + 1 )); exit_reason="agent failure exceeded retries"; exit_code=4
               break ;;
        esac
    done

    log "================================================================================"
    log "SESSION SUMMARY"
    log "================================================================================"
    log "Iterations: ${iteration}  Successful: ${success}  Failed: ${failures}"
    log "Duration: $(( $(date +%s) - session_start ))s"
    if [[ "$context_count" -gt 0 ]]; then
        local context_avg
        context_avg=$(( context_sum / context_count ))
        log "Context: min ${context_min}% / avg ${context_avg}% / max ${context_max}%  (window: ${context_window} tokens)"
    fi
    log "Exit: ${exit_reason} (code ${exit_code})"
    log "================================================================================"

    if [[ "$MODE" == "build" && "$exit_reason" == "completion signal" ]]; then
        plan_type=$(grep -m1 '^Plan Type:' "$RALPH_HOME/implementation_plan.md" 2>/dev/null \
            | sed 's/^Plan Type:[[:space:]]*//' || true)
        if [[ "$plan_type" == "process" ]]; then
            log ""
            log "╔══════════════════════════════════════════════════════════════════════════════════╗"
            log "║  Process-plan build complete. Target-state specs may need updating.            ║"
            log "║  Run: ralph align-specs                                                       ║"
            log "╚══════════════════════════════════════════════════════════════════════════════════╝"
        fi
    fi

    exit "$exit_code"
}

# ---------------------------------------------------------------------------
# Sandbox lifecycle commands
# ---------------------------------------------------------------------------
sandbox_ensure_name() {
    if [[ -z "${SANDBOX_NAME:-}" ]]; then
        local env_file="$RALPH_DIR/sandbox/.env"
        if [[ -f "$env_file" ]]; then
            local file_val
            file_val=$(grep -E '^SANDBOX_NAME=' "$env_file" 2>/dev/null | tail -1 | cut -d= -f2- || true)
            if [[ -n "$file_val" ]]; then
                export SANDBOX_NAME="$file_val"
                return
            fi
        fi
        local project_root
        project_root=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
        local hash
        hash=$(echo -n "$project_root" | sha1sum | cut -c1-8)
        local dir_name
        dir_name=$(basename "$project_root")
        export SANDBOX_NAME="${dir_name}-sandbox-${hash}"
        if [[ -f "$env_file" ]]; then
            echo "SANDBOX_NAME=${SANDBOX_NAME}" >> "$env_file"
        fi
    fi
}

sandbox_container_name() {
    local service="${1:-app}"
    local compose_file="$RALPH_DIR/sandbox/docker-compose.yml"
    local name
    name=$(docker compose -f "$compose_file" config --format json \
        | jq -r --arg svc "$service" '.services[$svc].container_name // empty' 2>/dev/null)
    if [[ -z "$name" ]]; then
        local project_name
        project_name=$(docker compose -f "$compose_file" config --format json \
            | jq -r '.name // empty' 2>/dev/null)
        if [[ -n "$project_name" ]]; then
            name="${project_name}-${service}-1"
        fi
    fi
    if [[ -z "$name" ]]; then
        echo "Error: could not determine container name for service '$service' from compose file." >&2
        exit 1
    fi
    echo "$name"
}

# ---------------------------------------------------------------------------
# Help system
# ---------------------------------------------------------------------------
help_index() {
    cat <<'EOF'
Ralph Help — run 'ralph help <topic>' for details.

  specs        Writing specs: target-state vs process, lifecycle, best practices
  plan         Planning modes: gap-driven vs sequence-constrained vs prompt, when to use each
  build        Build mode: task selection, signals, mid-implementation guidance
  prompt       Ad-hoc prompts: when and how to use ralph prompt
  sandbox      Sandbox lifecycle: setup, daily workflow, troubleshooting
  align-specs  Updating target-state specs after process-spec migrations
  retro        Post-cycle retrospective: reviewing results and improving inputs
EOF
}

help_plan() {
    cat <<'EOF'
PLANNING MODES
==============

Ralph supports three ways to drive work:

  ralph plan                Gap-driven planning
  ralph plan --process      Sequence-constrained planning
  ralph prompt <file>       Ad-hoc single-job prompt

GAP-DRIVEN PLANNING (ralph plan)
---------------------------------
Compares target-state specs in your specs directory to the current codebase
and infers what work remains. The planner decides task ordering. Use this
when you know what the system should look like but not the exact steps.

  - Reads specs from SPECS_DIR (default: specs/)
  - Generates implementation_plan.md with Plan Type: gap-driven
  - Discovery and investigation tasks are valid plan items

SEQUENCE-CONSTRAINED PLANNING (ralph plan --process)
-----------------------------------------------------
Decomposes human-defined phases into build-iteration-sized tasks. Phase
ordering from your process specs is authoritative — the planner works
within your structure, not around it. Use this for migrations, phased
refactors, ordered rollouts, or any work with explicit sequencing.

  - Reads process specs from PROCESS_DIR (set in config)
  - Generates implementation_plan.md with Plan Type: process
  - Discovery and investigation tasks are valid plan items

AD-HOC PROMPTS (ralph prompt <file>)
-------------------------------------
Runs a single prompt file in the loop — no planning phase, no specs
comparison. Use for one-off jobs: documentation, analysis, discovery.

REGENERATING A PLAN
-------------------
Delete implementation_plan.md and re-run the planning command, or simply
re-run it — the planner rebuilds the task list from scratch (preserving
useful notes from completed tasks).
EOF
}

help_specs() {
    cat <<'EOF'
WRITING SPECIFICATIONS
======================

TARGET-STATE SPECS
------------------
Describe what the system should be — behavior, APIs, constraints. You write
what you want; the planner figures out what's missing. This drives gap-driven
planning (ralph plan), where the planner compares your spec to the current
code and generates tasks to close the gaps.

  - Live in SPECS_DIR (default: specs/)
  - One feature per spec file
  - Include test criteria

PROCESS SPECS
-------------
Describe how to get there — phased migrations, ordered refactors, incremental
rollouts. You define the phases and their ordering; the planner decomposes
each phase into tasks. This drives sequence-constrained planning
(ralph plan --process), where the planner works within your human-defined
structure.

  - Live in PROCESS_DIR (set in config)
  - Only top-level *.md files are read (subdirectories ignored)
  - Archive completed specs to a subdirectory (e.g., archive/)

WHICH TYPE DO I NEED?
---------------------
  Phases with ordering constraints  →  process spec  →  ralph plan --process
  No sequencing constraints         →  target-state spec  →  ralph plan
  Single coherent job               →  ad-hoc prompt  →  ralph prompt <file>

TIPS
----
  - Be specific: concrete examples, explicit constraints, clear error cases
  - One feature per spec: easier to understand, update, and implement
  - Include test criteria: define how to verify the feature works
  - Don't mix spec types: keep target-state specs in SPECS_DIR, process specs
    in PROCESS_DIR

SPEC MAINTENANCE AFTER MIGRATIONS
----------------------------------
After completing a process-spec migration (ralph plan --process → ralph build),
target-state specs may be stale. Run:

  ralph align-specs

This updates target-state specs to reflect the post-migration system, using
process specs for intent and the implementation plan for build decisions.
EOF
}

help_build() {
    cat <<'EOF'
BUILD MODE
==========

Build mode implements one task per iteration from the implementation plan.

TASK SELECTION
--------------
Build mode is plan-type agnostic — it respects the plan's structure regardless
of how it was created:

  Plan Type: gap-driven   Tasks are a priority list; highest-priority planned
                          task is selected. Out-of-order selection requires a
                          documented reason.

  Plan Type: process      Phase headings are authoritative ordering constraints.
                          Work is selected from the earliest incomplete phase.

EXIT SIGNALS
------------
  <promise>COMPLETE</promise>   All tasks are complete (none planned or blocked).
                                The loop exits successfully.

  <promise>REPLAN</promise>     The plan needs restructuring, or only blocked tasks
                                remain. The loop exits so you can re-run the
                                planning command shown in Plan Command: at the
                                top of the plan.

MID-IMPLEMENTATION DISCOVERIES
-------------------------------
  Spec gaps:      Resolve via spec → code → conventions. Document assumptions.
  New work:       Add a task to the plan. Fix trivially if adjacent; else defer.
  Blocked:        Mark the task blocked, document why, stop the iteration.
  Architecture:   If it affects shared interfaces or multiple tasks → REPLAN.
                  If local → make the call and document it.
EOF
}

help_prompt() {
    cat <<'EOF'
AD-HOC PROMPTS
==============

  ralph prompt <file> [max_iterations]

Run a custom prompt through ralph's iteration loop — no planner, no task
selection, no implementation plan. Your prompt file replaces the built-in
plan/build prompts with a custom workflow while still leveraging the loop's
iteration, logging, and exit-signal machinery.

WHEN TO USE
-----------

  - Work that benefits from multiple iterations but doesn't fit the
    planner's task-decomposition model (spec review, test analysis,
    document assembly, codebase audits)
  - You want to define your own iteration strategy, progress tracking,
    and completion criteria
  - Quick one-shot jobs that just need one iteration

WHEN NOT TO USE
---------------

  - The work has phases or ordering constraints → ralph plan --process
  - The work is defined by target-state specs → ralph plan
  - You need the planner to decompose the work into tasks → use a planning mode

WRITING A MULTI-ITERATION PROMPT
---------------------------------

  Each iteration starts with fresh context — the agent has no memory of
  prior iterations. Effective multi-iteration prompts include:

  - A progress tracking file the agent reads first and updates last,
    serving as durable memory across iterations
  - A "fresh context" reminder so the agent treats repo files as the
    sole source of truth
  - Iteration sizing guidance (how much work per iteration)
  - Clear rules about what the agent should and should not modify

  CRITICAL: Your prompt MUST instruct the agent to output exactly
  <promise>COMPLETE</promise> when all work is done. This is the only
  way the loop knows to stop. Without it, ralph will keep iterating
  until max_iterations is reached.

  The built-in prompts in .ralph/prompts/ are good starting templates.
  Study prompts/build.md or prompts/plan.md for structure and conventions.

EXAMPLES
--------

  Single iteration:

    ralph prompt prompts/my-refactor.md

  Multi-iteration with a cap:

    ralph prompt prompts/spec-review.md 20
EOF
}

help_sandbox() {
    cat <<'EOF'
SANDBOX USAGE GUIDE
===================

The sandbox provides an isolated, multi-container Docker environment where
AI coding agents can work safely. The agent works in an "app" container with
its own copy of the codebase (cloned via git). Services (database, cache,
mail, etc.) run in their own containers using official Docker images, managed
by docker compose. Code flows in and out exclusively through git.

FIRST-TIME SETUP
----------------

  1. Generate sandbox files (Dockerfile, entrypoint, compose config):

       ralph sandbox setup

     Setup runs a multi-pass pipeline:
       - Analyze: scans the project and produces project-profile.json
       - Render: generates Dockerfile, docker-compose.yml, entrypoint.sh,
         and .env.example from the profile
       - Validate: checks generated files for structural correctness
       - Repair: if validation fails, attempts automated fixes

  2. Create your .env with tokens:

       cp .ralph/sandbox/.env.example .ralph/sandbox/.env

     Edit .ralph/sandbox/.env and set GITHUB_TOKEN and AMP_API_KEY.

  3. Start the sandbox:

       ralph sandbox up

     The first build takes several minutes (builds app image, pulls service
     images, clones the repo, runs migrations). Subsequent starts are fast.

  4. Open a shell inside the sandbox:

       ralph sandbox shell

DAILY WORKFLOW
--------------

  ralph sandbox up           Start the sandbox (rebuilds if files changed)
  ralph sandbox shell        Open a bash shell as the "ralph" user
  ralph sandbox status       Check container status and service health
  ralph sandbox stop         Stop the sandbox (preserves container state)

REGENERATING SANDBOX FILES
--------------------------

  ralph sandbox setup --force

  Re-runs the full multi-pass pipeline to regenerate all sandbox files from
  scratch. Your .env file (containing tokens) is automatically preserved.

  After regenerating, review .env.example for any new variables that
  may need to be added to your .env.

FIXING WRONG DETECTIONS (--render-only)
---------------------------------------

  The --render-only flag skips the analysis pass and reuses the existing
  project-profile.json. The --force flag allows overwriting existing sandbox
  files. They are independent flags but typically used together.

  If setup detected the wrong stack, runtime version, or services, edit
  .ralph/sandbox/project-profile.json to correct it, then regenerate:

    ralph sandbox setup --render-only --force

  Also useful after updating prompt templates — regenerate sandbox files
  from the same profile without re-analyzing the project.

CUSTOMIZING THE SANDBOX (sandbox-preferences.sh)
-------------------------------------------------

  Edit .ralph/sandbox-preferences.sh to add extra packages, tools, or
  configuration to the sandbox. This script runs during "docker build"
  and is applied byte-for-byte — no LLM interpretation.

  After editing, rebuild with:

    ralph sandbox up

RESETTING THE SANDBOX
---------------------

  ralph sandbox reset        Wipe app volume (service data preserved)
  ralph sandbox reset --all  Wipe all volumes (app + database + cache)

  A reset deletes the app container's codebase volume, then restarts it.
  On restart, the entrypoint re-clones from git, reinstalls dependencies,
  and re-runs migrations — a fresh working state from the same config.

  Use "reset" when the codebase is corrupted but database data is fine.
  Use "reset --all" for a complete clean-room rebuild — all volumes are
  deleted and everything is reconstructed from scratch.

RESETTING VS REGENERATING
-------------------------

  "setup" and "reset" operate at different layers:

  - "setup" regenerates the sandbox configuration files (Dockerfile,
    docker-compose.yml, entrypoint.sh). Use when the sandbox definition
    is wrong — wrong stack, missing service, or updated prompts.

  - "reset" wipes runtime data (Docker volumes) but leaves configuration
    files untouched. Use when the agent corrupted the codebase or you
    need a fresh start from the existing configuration.

TROUBLESHOOTING
---------------

  Container won't stay running?
    Check logs:  docker compose -f .ralph/sandbox/docker-compose.yml logs

  Healthcheck failing?
    The healthcheck uses "supervisorctl status" and has a 60-second start
    period. On first run, the entrypoint installs dependencies and runs
    migrations before supervisord starts. Wait a few minutes, then check:
      ralph sandbox status

  Port conflicts?
    Set alternate ports in .ralph/sandbox/.env:
      SANDBOX_HTTP_PORT=8080
      SANDBOX_DB_PORT=54321

  Multiple checkouts of the same project?
    SANDBOX_NAME is auto-derived from the checkout path to avoid collisions.
    Override it in .ralph/sandbox/.env if the auto-generated name is not suitable.

  Base image out of date?
    The base image is auto-refreshed on every "ralph sandbox up", so changes
    from "ralph update" take effect automatically — no manual rebuild needed.

UPDATING AGENTS.md FOR SANDBOX COMMANDS
---------------------------------------

  If your AGENTS.md has environment-specific commands (e.g., prefixed with
  "./vendor/bin/sail"), add sandbox variants so agents know which style to
  use. The SANDBOX environment variable (SANDBOX=1 inside the container)
  lets agents detect their environment.

  Recommended pattern — add a table like this to your AGENTS.md:

    ## Running Commands

    | Environment       | Prefix               | Example                                  |
    |-------------------|-----------------------|------------------------------------------|
    | Host (Sail)       | ./vendor/bin/sail     | ./vendor/bin/sail artisan migrate        |
    | Sandbox container | (none)                | php artisan migrate                      |

    How to detect: check the SANDBOX environment variable.
    If SANDBOX=1, run commands directly. Otherwise, use the host prefix.

DOCUMENTING FIXES (sandbox-setup.md)
-------------------------------------

  sandbox setup creates a sandbox-setup.md file for documenting fixes and
  bootstrap steps that the setup agent missed or got wrong. Two sections:

  - Host-Side Fixes: corrections to generated sandbox files (Dockerfile,
    entrypoint, docker-compose.yml). Reference these when regenerating
    with "sandbox setup --force".

  - In-Sandbox Bootstrap: steps for agents inside a fresh sandbox after
    "sandbox reset" or first "sandbox up" (db migrations, test db setup,
    seed data, etc).

  This file is never overwritten by ralph. Reference it from AGENTS.md
  if you want agents to act on the notes.
EOF
}

help_align_specs() {
    cat <<'EOF'
ALIGN SPECS
===========

Update target-state specs after a process-spec-driven migration so they
reflect the post-migration system.

PURPOSE
-------
After 'ralph plan --process' and 'ralph build' complete a migration,
target-state specs in SPECS_DIR still describe the pre-migration system.
'ralph align-specs' invokes an agent to update those specs using process
specs for design intent, the implementation plan for build decisions, and
the codebase for current reality.

Without alignment, future 'ralph plan' (gap-driven) runs generate nonsense
tasks against stale specs.

PREREQUISITES
-------------
All three are required:

  1. PROCESS_DIR configured and non-empty (set in config)
  2. implementation_plan.md exists with Plan Type: process
  3. At least one completed task in the plan

ALIGNMENT LEDGER
----------------
The alignment ledger (alignment_ledger.md) tracks which specs have been
reviewed and updated — persistent memory across fresh-context iterations,
like implementation_plan.md for build mode.

To reset alignment progress: delete alignment_ledger.md and re-run.

WORKFLOW
--------
  ralph align-specs [max_iterations]

First iteration: the agent surveys all inputs, creates the ledger listing
affected specs, and begins aligning. Subsequent iterations: the agent reads
the ledger and picks up where it left off.

BLOCKED SPECS
-------------
When the agent encounters irreconcilable conflicts (process specs contradict,
codebase diverged from intent), it marks the spec as 'blocked' in the ledger
with a reason. The agent continues aligning non-blocked specs.

To resolve: review the ledger, fix the conflict, and re-run.
EOF
}

help_retro() {
    cat <<'EOF'
RETROSPECTIVE
=============

After a plan+build cycle, review what happened and improve your inputs
for the next cycle. This is a human-driven process — you analyze the
results, identify patterns, and update specs, AGENTS.md, and prompts.

WHEN TO DO A RETRO
------------------
After every significant plan+build cycle, especially when:
  - Build agents struggled, blocked frequently, or triggered REPLAN
  - Tasks took more iterations than expected
  - You see repeated patterns in agent mistakes
  - The plan needed manual editing mid-build

WHAT TO REVIEW
--------------

  1. Session logs (.ralph/logs/session-*.log or logs/session-*.log)
     - How many iterations did each task take?
     - Were there retries or agent failures?
     - Did agents waste iterations on wrong approaches?

  2. Implementation plan (implementation_plan.md)
     - Blocked tasks: why were they blocked? Could the spec have prevented it?
     - "Assumption / Spec gap:" notes: these are specs that need tightening
     - "Conflict:" notes: sources of truth that disagree
     - Tasks added during build: were they foreseeable during planning?
     - Task sizing: were tasks too large (multi-iteration) or too small?

  3. Git history (git log --oneline)
     - Are commit messages clear and descriptive?
     - Were there revert commits or fix-up commits?
     - Did agents commit unrelated changes?

  4. AGENTS.md effectiveness
     - Did agents use the correct test/build/lint commands?
     - Did agents follow project conventions?
     - Were there environment-specific issues (paths, tools, versions)?

  5. Spec quality
     - Did agents misinterpret any specs?
     - Were verification criteria clear enough for agents to know when done?
     - Were there ambiguities that led to guessing?

COMMON FAILURE PATTERNS
-----------------------

  Wrong test commands     → Update AGENTS.md with exact commands and flags
  Unclear "done" state    → Add a Verify section to specs with concrete checks
  Agent scope creep       → Tighten task descriptions in specs, add constraints
  Repeated mistakes       → Add a "Pitfalls" or "Do NOT" section to AGENTS.md
  Bad task sizing          → Review task sizing heuristics in your specs;
                             add examples of good vs bad decomposition
  Spec ambiguity          → Add concrete examples, explicit edge cases,
                             sample inputs/outputs
  Missing prerequisites   → Add dependency/environment setup to AGENTS.md
  Stale plan              → Delete implementation_plan.md and re-plan more often

WHERE TO APPLY FIXES
--------------------

  AGENTS.md               Operational knowledge: commands, environment, conventions,
                          pitfalls. This is what agents read every iteration — keep
                          it concise and accurate.

  Specs (specs/*.md)      Behavioral definitions: what the system should do, how to
                          verify it works. Tighten ambiguous areas, add Verify blocks,
                          add examples.

  Prompts (prompts/*.md)  Structural changes to how agents approach planning or
                          building. Change these rarely and carefully — they affect
                          all projects using ralph.

RETRO CHECKLIST
---------------

  [ ] Read the session log — note iterations per task, failures, retries
  [ ] Scan the plan for Assumption/Spec gap and Conflict notes
  [ ] Check git log for revert/fixup commits or unclear messages
  [ ] Identify the top 2-3 issues that cost the most wasted iterations
  [ ] For each issue, decide: AGENTS.md fix, spec fix, or prompt fix?
  [ ] Apply the fixes
  [ ] Commit the improvements before the next plan+build cycle

AGENT-ASSISTED ANALYSIS
------------------------
You can use an interactive agent session to help analyze a cycle. Start
a session with your preferred agent and paste the prompt below. The agent
will read your session logs, plan, and git history, then walk through the
retro with you.

Session log files are in .ralph/logs/ (or logs/ in the ralph-loop repo).
Filenames encode the mode and timestamp, e.g.:

  session-20250320-140000-plan.log
  session-20250320-150000-build.log
  session-20250321-090000-build.log

A single plan+build cycle may span multiple session files (e.g., two
separate 'ralph build' runs). Tell the agent which sessions to review,
or let it identify the most recent cycle from the timestamps.

  --- copy from here ---

  Ralph is an iterative development system for LLM coding agents. It
  works in cycles: plan mode analyzes specs and creates an implementation
  plan, then build mode implements one task per iteration with fresh
  agent context. Help me do a retrospective on my last plan+build cycle.

  1. List the session logs in .ralph/logs/ (or logs/) and identify
     which sessions belong to the most recent plan+build cycle.
     Confirm with me before proceeding.

  2. Read those session logs, .ralph/implementation_plan.md (or
     implementation_plan.md), and run 'git log --oneline' for the
     relevant date range.

  3. Analyze and report:
     - Iterations per task (how many iterations did each task take?)
     - Agent failures, retries, and wasted iterations
     - Blocked tasks and REPLAN signals — root causes
     - All "Assumption / Spec gap:" and "Conflict:" notes in the plan
     - Tasks added during build that could have been planned
     - Task sizing issues (too large, too small)
     - Git history: reverts, fixups, unclear commit messages
     - AGENTS.md issues: wrong commands, missing conventions
     - Spec quality: ambiguities, missing verification criteria

  4. Rank the top issues by wasted iterations / effort.

  5. For each issue, recommend where to fix it:
     - AGENTS.md (operational: commands, environment, pitfalls)
     - Specs (behavioral: verification, examples, constraints)
     - Prompts (structural: change rarely, affects all projects)

  6. Let's discuss the findings and decide which fixes to apply.

  --- end copy ---

SHARING FEEDBACK WITH RALPH-LOOP
---------------------------------
After a retro, you can share structural observations with the ralph-loop
project to help improve prompts and defaults — without revealing anything
about your project.

Use the prompt below to generate a sanitized summary. The agent reads your
retro artifacts and produces a report stripped of project-specific details:
no file paths, domain names, business logic, or code snippets. Only
structural patterns and ralph-specific observations are included.

  --- copy from here ---

  Ralph is an iterative development system for LLM coding agents. It
  works in cycles: plan mode analyzes specs and creates an implementation
  plan, then build mode implements one task per iteration with fresh
  agent context. Generate a sanitized retro summary I can share with the
  ralph-loop project. Read the session logs, implementation plan, and
  git log from the cycle we just reviewed.

  INCLUDE (structural observations only):
  - Planning mode used (gap-driven / process)
  - Number of plan iterations and build iterations
  - Iteration-to-task ratio (how efficient was the cycle?)
  - Number of blocked tasks, REPLAN signals, agent retries
  - Categories of spec gaps encountered (not the gaps themselves)
  - Categories of AGENTS.md fixes needed (e.g., "test commands",
    "environment setup", "conventions")
  - Task sizing observations (too granular, too coarse, about right)
  - Any suggestions for ralph-loop prompts or defaults
  - Agent type used (amp, claude, cline, etc.)

  EXCLUDE (project secrets):
  - Project name, domain, or business context
  - File paths, module names, or API endpoints
  - Code snippets or implementation details
  - Team member names
  - Specific spec content or task descriptions

  Format as a GitHub issue body I can paste into:
    https://github.com/mjeffe/ralph-loop/issues
  Use the title: "Retro feedback: [one-line summary]"

  --- end copy ---
EOF
}

ralph_help() {
    local topic="${1:-}"
    case "$topic" in
        "")          help_index ;;
        specs)       help_specs ;;
        plan)        help_plan ;;
        build)       help_build ;;
        prompt)      help_prompt ;;
        sandbox)     help_sandbox ;;
        align-specs) help_align_specs ;;
        retro)       help_retro ;;
        *)           echo "Unknown help topic: $topic" >&2; echo; help_index ;;
    esac
}

detect_stack() {
    # Framework-specific indicators first (most distinctive wins)

    # PHP/Laravel — artisan file is the strongest Laravel signal
    if [[ -f "artisan" ]] \
        || { [[ -f "composer.json" ]] && grep -q '"laravel/framework"' composer.json 2>/dev/null; }; then
        echo "php-laravel"
        return
    fi

    # PHP (generic)
    if [[ -f "composer.json" ]]; then
        echo "php"
        return
    fi

    # Ruby/Rails
    if [[ -f "bin/rails" ]] \
        || { [[ -f "Gemfile" ]] && grep -q "rails" Gemfile 2>/dev/null; }; then
        echo "rails"
        return
    fi

    # Ruby (generic)
    if [[ -f "Gemfile" ]]; then
        echo "ruby"
        return
    fi

    # Python/Django
    if [[ -f "manage.py" ]] && grep -q "django" manage.py 2>/dev/null; then
        echo "python-django"
        return
    fi

    # Python (generic)
    if [[ -f "pyproject.toml" ]] || [[ -f "requirements.txt" ]] \
        || [[ -f "Pipfile" ]] || [[ -f "setup.py" ]]; then
        echo "python"
        return
    fi

    # Go
    if [[ -f "go.mod" ]]; then
        echo "go"
        return
    fi

    # Rust
    if [[ -f "Cargo.toml" ]]; then
        echo "rust"
        return
    fi

    # Node.js — checked LAST because many non-Node projects have
    # package.json for frontend tooling (Laravel, Rails, Django, etc.)
    if [[ -f "package.json" ]]; then
        echo "node"
        return
    fi

    echo ""
}

sandbox_validate_profile() {
    local profile_file="$1"
    local failures=""

    if [[ ! -f "$profile_file" ]]; then
        echo "[FAIL] profile file not found: $profile_file"
        return
    fi

    if ! jq empty "$profile_file" 2>/dev/null; then
        echo "[FAIL] profile is not valid JSON"
        return
    fi

    local required_fields=(schema_version stack runtimes package_managers services
        system_packages git_provider git_remote workdir env_overrides bootstrap
        supervisor_programs compose_ports assumptions notes)

    for field in "${required_fields[@]}"; do
        if ! jq -e "has(\"$field\")" "$profile_file" >/dev/null 2>&1; then
            failures+="[FAIL] missing required field: $field"$'\n'
        fi
    done

    local schema_version
    schema_version=$(jq -r '.schema_version // empty' "$profile_file" 2>/dev/null)
    if [[ -n "$schema_version" && "$schema_version" != "1" ]]; then
        failures+="[FAIL] schema_version must be 1, got: $schema_version"$'\n'
    fi

    local runtime_count
    runtime_count=$(jq '.runtimes | length' "$profile_file" 2>/dev/null || echo 0)
    if [[ "$runtime_count" -eq 0 ]]; then
        failures+="[FAIL] runtimes must have at least one entry"$'\n'
    fi

    local supervisor_count
    supervisor_count=$(jq '.supervisor_programs | length' "$profile_file" 2>/dev/null || echo 0)
    if [[ "$supervisor_count" -eq 0 ]]; then
        failures+="[FAIL] supervisor_programs must have at least one entry"$'\n'
    fi

    local service_count
    service_count=$(jq '.services | length' "$profile_file" 2>/dev/null || echo 0)
    if [[ "$service_count" -gt 0 ]]; then
        local service_errors
        service_errors=$(jq -r '
            .services | to_entries[] |
            ( if .value.name == null then "[FAIL] services[\(.key)] missing required field: name" else empty end ),
            ( if .value.image == null then "[FAIL] services[\(.key)] missing required field: image" else empty end ),
            ( if (.value.port == null and .value.ports == null) then "[FAIL] services[\(.key)] missing required field: port or ports" else empty end ),
            ( if .value.reason == null then "[FAIL] services[\(.key)] missing required field: reason" else empty end )
        ' "$profile_file" 2>/dev/null)
        if [[ -n "$service_errors" ]]; then
            failures+="$service_errors"$'\n'
        fi
    fi

    # Output failures (empty = pass)
    if [[ -n "$failures" ]]; then
        echo -n "$failures"
    fi
}

sandbox_validate() {
    local sandbox_dir="$1"
    local failures=""

    # --- Syntax checks ---
    if [[ -f "$sandbox_dir/entrypoint.sh" ]]; then
        if bash -n "$sandbox_dir/entrypoint.sh" 2>/dev/null; then
            : # pass
        else
            failures+="[FAIL] entrypoint.sh syntax error"$'\n'
        fi
    else
        failures+="[FAIL] entrypoint.sh not found"$'\n'
    fi

    if [[ -f "$sandbox_dir/docker-compose.yml" ]]; then
        if docker compose -f "$sandbox_dir/docker-compose.yml" config >/dev/null 2>&1; then
            : # pass
        else
            failures+="[FAIL] docker-compose.yml syntax error"$'\n'
        fi
    else
        failures+="[FAIL] docker-compose.yml not found"$'\n'
    fi

    if [[ -f "$sandbox_dir/sandbox-preferences.sh" ]]; then
        if bash -n "$sandbox_dir/sandbox-preferences.sh" 2>/dev/null; then
            : # pass
        else
            failures+="[FAIL] sandbox-preferences.sh syntax error"$'\n'
        fi
    fi

    # --- Structural: Dockerfile ---
    if [[ -f "$sandbox_dir/Dockerfile" ]]; then
        if ! grep -q 'FROM ralph-sandbox-base' "$sandbox_dir/Dockerfile"; then
            failures+="[FAIL] Dockerfile missing FROM ralph-sandbox-base"$'\n'
        fi
        if ! grep -q 'ENTRYPOINT.*tini' "$sandbox_dir/Dockerfile"; then
            failures+="[FAIL] Dockerfile ENTRYPOINT does not use tini"$'\n'
        fi
        if ! grep -q 'entrypoint.sh' "$sandbox_dir/Dockerfile"; then
            failures+="[FAIL] Dockerfile does not copy entrypoint.sh"$'\n'
        fi
        if ! grep -q 'WORKDIR' "$sandbox_dir/Dockerfile"; then
            failures+="[FAIL] Dockerfile missing WORKDIR"$'\n'
        fi
        if ! grep -q 'sandbox-preferences.sh' "$sandbox_dir/Dockerfile"; then
            failures+="[FAIL] Dockerfile does not COPY sandbox-preferences.sh"$'\n'
        fi
    else
        failures+="[FAIL] Dockerfile not found"$'\n'
    fi

    # --- Structural: entrypoint.sh ---
    if [[ -f "$sandbox_dir/entrypoint.sh" ]]; then
        local first_line second_line
        first_line=$(head -n1 "$sandbox_dir/entrypoint.sh")
        second_line=$(sed -n '2p' "$sandbox_dir/entrypoint.sh")
        if [[ "$first_line" != "#!/usr/bin/env bash" ]]; then
            failures+="[FAIL] entrypoint.sh does not start with #!/usr/bin/env bash"$'\n'
        fi
        if [[ "$second_line" != "set -euo pipefail" ]]; then
            failures+="[FAIL] entrypoint.sh missing set -euo pipefail on line 2"$'\n'
        fi
        if ! grep -q 'git.*credential\|credential.*git' "$sandbox_dir/entrypoint.sh"; then
            failures+="[FAIL] entrypoint.sh missing git credential configuration"$'\n'
        fi
        if ! grep -q '\.git/HEAD' "$sandbox_dir/entrypoint.sh"; then
            failures+="[FAIL] entrypoint.sh missing clone logic (.git/HEAD check)"$'\n'
        fi
        if ! grep -q 'exec supervisord' "$sandbox_dir/entrypoint.sh"; then
            failures+="[FAIL] entrypoint.sh does not end with exec supervisord"$'\n'
        fi
    fi

    # --- Structural: docker-compose.yml ---
    if [[ -f "$sandbox_dir/docker-compose.yml" ]]; then
        if ! grep -q 'app:' "$sandbox_dir/docker-compose.yml"; then
            failures+="[FAIL] docker-compose.yml missing app service"$'\n'
        fi
        if grep -qE '^\s+environment:' "$sandbox_dir/docker-compose.yml"; then
            # Check for map syntax (KEY: value) vs list syntax (- KEY=value) under environment
            if grep -A 20 'environment:' "$sandbox_dir/docker-compose.yml" | grep -qE '^\s+[A-Z_]+:'; then
                failures+="[FAIL] docker-compose.yml uses map syntax for environment (should use list syntax)"$'\n'
            fi
        fi
        if grep -q 'volumes:' "$sandbox_dir/docker-compose.yml" && grep -qE '^\s+-\s+[./]' "$sandbox_dir/docker-compose.yml"; then
            failures+="[FAIL] docker-compose.yml uses bind mounts (should use named volumes only)"$'\n'
        fi
        if ! grep -q 'env_file' "$sandbox_dir/docker-compose.yml"; then
            failures+="[FAIL] docker-compose.yml missing env_file directive"$'\n'
        fi
        if ! grep -q 'tty: true\|tty:true' "$sandbox_dir/docker-compose.yml"; then
            failures+="[FAIL] docker-compose.yml missing tty: true for app service"$'\n'
        fi
        if ! grep -q 'stdin_open: true\|stdin_open:true' "$sandbox_dir/docker-compose.yml"; then
            failures+="[FAIL] docker-compose.yml missing stdin_open: true for app service"$'\n'
        fi
    fi

    # --- Cross-file: ports ---
    if [[ -f "$sandbox_dir/Dockerfile" && -f "$sandbox_dir/docker-compose.yml" ]]; then
        local exposed_ports
        exposed_ports=$(grep -oP 'EXPOSE\s+\K\d+' "$sandbox_dir/Dockerfile" 2>/dev/null || true)
        for port in $exposed_ports; do
            if ! grep -q "$port" "$sandbox_dir/docker-compose.yml"; then
                failures+="[FAIL] Dockerfile EXPOSE $port has no corresponding port mapping in docker-compose.yml"$'\n'
            fi
        done
    fi

    # --- Cross-file: env vars in compose documented in .env.example ---
    if [[ -f "$sandbox_dir/docker-compose.yml" && -f "$sandbox_dir/.env.example" ]]; then
        local compose_vars
        compose_vars=$(grep -oP '\$\{?\K[A-Z_]+' "$sandbox_dir/docker-compose.yml" 2>/dev/null | sort -u || true)
        for var in $compose_vars; do
            if ! grep -qP "^#?\s*${var}=" "$sandbox_dir/.env.example" 2>/dev/null; then
                failures+="[FAIL] compose env var $var not documented in .env.example"$'\n'
            fi
        done
    fi

    # --- Cross-file: entrypoint references unprovisioned runtime managers ---
    if [[ -f "$sandbox_dir/entrypoint.sh" && -f "$sandbox_dir/Dockerfile" ]]; then
        local runtime_managers="nvm\.sh|pyenv init|rbenv init|\.asdf/asdf\.sh|sdkman-init\.sh|volta"
        local entrypoint_refs
        entrypoint_refs=$(grep -oP "$runtime_managers" "$sandbox_dir/entrypoint.sh" 2>/dev/null || true)
        for ref in $entrypoint_refs; do
            if ! grep -q "$ref" "$sandbox_dir/Dockerfile" 2>/dev/null; then
                failures+="[FAIL] entrypoint.sh references '$ref' but Dockerfile does not install it"$'\n'
            fi
        done
    fi

    # --- Profile consistency ---
    if [[ -f "$sandbox_dir/project-profile.json" ]]; then
        # Services in compose match profile
        if [[ -f "$sandbox_dir/docker-compose.yml" ]]; then
            local profile_services
            profile_services=$(jq -r '.services[].name' "$sandbox_dir/project-profile.json" 2>/dev/null || true)
            for svc in $profile_services; do
                if ! grep -q "${svc}:" "$sandbox_dir/docker-compose.yml" 2>/dev/null; then
                    failures+="[FAIL] profile service '$svc' not found in docker-compose.yml"$'\n'
                fi
            done
        fi
    fi

    # Output failures (empty = pass)
    if [[ -n "$failures" ]]; then
        echo -n "$failures"
    fi
}

sandbox_setup() {
    local sandbox_dir="$RALPH_DIR/sandbox"
    local force=0
    local render_only=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force) force=1; shift ;;
            --render-only) render_only=1; shift ;;
            *) echo "Error: unknown option for sandbox setup: $1" >&2; exit 1 ;;
        esac
    done

    # Load agent script (needed for agent_invoke)
    AGENT_SCRIPT="$RALPH_DIR/agents/${AGENT}.sh"
    if [[ ! -f "$AGENT_SCRIPT" ]]; then
        echo "Error: agent script not found: $AGENT_SCRIPT" >&2
        exit 1
    fi
    # shellcheck source=/dev/null
    source "$AGENT_SCRIPT"

    if ! command -v "$AGENT_CLI" &>/dev/null; then
        echo "Error: agent CLI not found in PATH: $AGENT_CLI" >&2
        exit 1
    fi

    # --render-only requires an existing profile
    if [[ "$render_only" -eq 1 && ! -f "$sandbox_dir/project-profile.json" ]]; then
        echo "Error: no project profile found at $sandbox_dir/project-profile.json" >&2
        echo "Run 'ralph sandbox setup' first (without --render-only)." >&2
        exit 1
    fi

    # Handle existing sandbox files
    if [[ -f "$sandbox_dir/Dockerfile" ]]; then
        if [[ "$force" -eq 0 ]]; then
            echo "Sandbox files already exist in $sandbox_dir/"
            echo "Use --force to regenerate."
            exit 1
        fi
        # Preserve .env across regeneration (contains user secrets/tokens)
        local saved_env=""
        if [[ -f "$sandbox_dir/.env" ]]; then
            saved_env=$(mktemp)
            cp "$sandbox_dir/.env" "$saved_env"
        fi
        if [[ "$render_only" -eq 1 ]]; then
            # Preserve profile — only delete generated files
            local saved_profile
            saved_profile=$(mktemp)
            cp "$sandbox_dir/project-profile.json" "$saved_profile"
            rm -rf "$sandbox_dir"
            mkdir -p "$sandbox_dir"
            cp "$saved_profile" "$sandbox_dir/project-profile.json"
            rm -f "$saved_profile"
        else
            rm -rf "$sandbox_dir"
        fi
    fi

    mkdir -p "$sandbox_dir"

    # Copy base Dockerfile, wait-for-db, and sandbox-preferences into build context
    cp "$RALPH_DIR/prompts/templates/Dockerfile.base" "$sandbox_dir/Dockerfile.base"
    cp "$RALPH_DIR/prompts/templates/wait-for-db" "$sandbox_dir/wait-for-db"
    cp "$RALPH_DIR/sandbox-preferences.sh" "$sandbox_dir/sandbox-preferences.sh"

    # Build base image (deterministic, no LLM involved)
    echo "Building sandbox base image..."
    docker build -t ralph-sandbox-base \
        -f "$sandbox_dir/Dockerfile.base" \
        "$sandbox_dir/"

    if [[ "$render_only" -eq 0 ]]; then
        # Detect stack and resolve playbook
        local STACK
        STACK=$(detect_stack)
        local PLAYBOOK_FILE="$RALPH_DIR/prompts/playbooks/${STACK}.md"
        if [[ -n "$STACK" && -f "$PLAYBOOK_FILE" ]]; then
            export STACK_PLAYBOOK="$PLAYBOOK_FILE"
        else
            export STACK_PLAYBOOK=""
        fi

        # Pass 1: Analyze project → project profile
        echo "Analyzing project..."
        local analyze_prompt
        analyze_prompt=$(mktemp)
        prepare_prompt "$RALPH_DIR/prompts/sandbox-analyze.md" "$analyze_prompt"
        agent_invoke "$analyze_prompt" | agent_format_display
        rm -f "$analyze_prompt"

        if [[ ! -f "$sandbox_dir/project-profile.json" ]]; then
            echo "Error: analysis did not produce project-profile.json" >&2
            exit 1
        fi
    else
        echo "Using existing project profile (--render-only)."
    fi

    # Validate profile schema before Pass 2
    local profile_errors
    profile_errors=$(sandbox_validate_profile "$sandbox_dir/project-profile.json")
    if [[ -n "$profile_errors" ]]; then
        echo "Error: project profile has schema errors:" >&2
        echo "$profile_errors" >&2
        exit 1
    fi

    # Pass 2: Generate files from profile
    echo "Generating sandbox files..."
    local render_prompt
    render_prompt=$(mktemp)
    prepare_prompt "$RALPH_DIR/prompts/sandbox-render.md" "$render_prompt"
    agent_invoke "$render_prompt" | agent_format_display
    rm -f "$render_prompt"

    # Validate generated files
    local validation_failures
    validation_failures=$(sandbox_validate "$sandbox_dir")
    if [[ -n "$validation_failures" ]]; then
        echo ""
        echo "Validation found issues:"
        echo "$validation_failures"

        # Pass 3: Repair
        echo ""
        echo "Attempting automated repair..."
        export VALIDATION_FAILURES="$validation_failures"
        local repair_prompt
        repair_prompt=$(mktemp)
        prepare_prompt "$RALPH_DIR/prompts/sandbox-repair.md" "$repair_prompt"
        agent_invoke "$repair_prompt" | agent_format_display
        rm -f "$repair_prompt"

        # Re-validate
        validation_failures=$(sandbox_validate "$sandbox_dir")
        if [[ -n "$validation_failures" ]]; then
            echo ""
            echo "Remaining issues after repair:"
            echo "$validation_failures"
            echo ""
            echo "Please fix these manually before running 'ralph sandbox up'."
        fi
    fi

    # Create sandbox-setup.md if it doesn't exist (user-owned, never overwritten)
    local setup_notes="$RALPH_DIR/sandbox-setup.md"
    if [[ ! -f "$setup_notes" ]]; then
        cat > "$setup_notes" <<'NOTES'
# Sandbox Setup Notes

## Host-Side Fixes
<!-- Corrections to generated sandbox files (Dockerfile, entrypoint,
     docker-compose.yml) that `ralph sandbox setup` got wrong.
     Reference these when regenerating with `sandbox setup --force`. -->

## In-Sandbox Bootstrap
<!-- Steps for getting the application working inside a fresh sandbox
     (after `sandbox reset` or first `sandbox up`): database migrations,
     test database setup, seed data, dev server config, etc. -->
NOTES
    fi

    # Restore .env if preserved from --force
    if [[ -n "${saved_env:-}" && -f "$saved_env" ]]; then
        cp "$saved_env" "$sandbox_dir/.env"
        rm -f "$saved_env"
        echo ""
        echo "Restored existing .env (your tokens are preserved)."
        echo ""
        echo "Next steps:"
        echo "  1. Review $sandbox_dir/.env against .env.example for any new variables"
        echo "  2. Run 'ralph sandbox up' to start the sandbox"
    else
        echo ""
        echo "Next steps:"
        echo "  1. cp $sandbox_dir/.env.example $sandbox_dir/.env"
        echo "  2. Edit $sandbox_dir/.env and set GITHUB_TOKEN and AMP_API_KEY"
        echo "  3. Run 'ralph sandbox up' to start the sandbox"
    fi
    echo ""
    echo "Tip: Use $RALPH_HOME/sandbox-setup.md to document sandbox fixes and bootstrap steps."
    echo "     See 'ralph help sandbox' for details."
}

sandbox_up() {
    sandbox_ensure_name
    local compose_file="$RALPH_DIR/sandbox/docker-compose.yml"
    if [[ ! -f "$compose_file" ]]; then
        echo "Sandbox not configured. Run 'ralph sandbox setup' first." >&2
        exit 1
    fi

    local env_file="$RALPH_DIR/sandbox/.env"
    if [[ ! -f "$env_file" ]]; then
        echo "Warning: $env_file not found." >&2
        echo "Copy .env.example to .env and set GITHUB_TOKEN and AMP_API_KEY:" >&2
        echo "  cp $RALPH_DIR/sandbox/.env.example $env_file" >&2
        exit 1
    fi

    # Auto-refresh base image and sandbox-preferences from managed sources.
    # Docker layer cache makes this instant when nothing has changed.
    cp "$RALPH_DIR/prompts/templates/Dockerfile.base" "$RALPH_DIR/sandbox/Dockerfile.base"
    cp "$RALPH_DIR/sandbox-preferences.sh" "$RALPH_DIR/sandbox/sandbox-preferences.sh"
    docker build -t ralph-sandbox-base -f "$RALPH_DIR/sandbox/Dockerfile.base" "$RALPH_DIR/sandbox/"

    docker compose -f "$compose_file" up -d --build "$@"
    echo ""
    echo "Sandbox is starting. First build may take several minutes."
    echo "Use 'ralph sandbox shell' to connect once ready."
}

sandbox_stop() {
    sandbox_ensure_name
    docker compose -f "$RALPH_DIR/sandbox/docker-compose.yml" stop "$@"
}

sandbox_reset() {
    sandbox_ensure_name
    local compose_file="$RALPH_DIR/sandbox/docker-compose.yml"
    local reset_all=false

    if [[ "${1:-}" == "--all" ]]; then
        reset_all=true
    fi

    local project_name
    project_name=$(docker compose -f "$compose_file" config --format json \
        | jq -r '.name // empty' 2>/dev/null)

    if [[ -z "$project_name" ]]; then
        echo "Error: could not determine compose project name." >&2
        exit 1
    fi

    if [[ "$reset_all" == true ]]; then
        echo "This will delete ALL sandbox volumes (codebase, database, cache, etc.)."
    else
        echo "This will delete the app codebase volume and re-clone from git."
        echo "Service volumes (database, cache, etc.) will be preserved."
    fi
    read -p "Continue? [y/N] " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        if [[ "$reset_all" == true ]]; then
            # Remove all containers and all volumes across every service
            docker compose -f "$compose_file" down -v
        else
            # Stop only the app service, remove its codebase volume
            docker compose -f "$compose_file" stop app
            docker volume rm "${project_name}_sandbox-codebase" 2>/dev/null || true
            docker compose -f "$compose_file" up -d --build app
        fi
        echo "Sandbox reset complete."
    fi
}

sandbox_shell() {
    sandbox_ensure_name
    local container_name
    container_name=$(sandbox_container_name "app")
    docker exec -it -u ralph "$container_name" bash
}

sandbox_status() {
    sandbox_ensure_name
    local compose_file="$RALPH_DIR/sandbox/docker-compose.yml"
    if [[ ! -f "$compose_file" ]]; then
        echo "Sandbox not configured. Run 'ralph sandbox setup' first." >&2
        exit 1
    fi
    docker compose -f "$compose_file" ps "$@"
}

# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------
validate_prerequisites

if [[ "$MODE" == "help" ]]; then
    ralph_help "$HELP_TOPIC"
    exit 0
fi

case "$MODE" in
    plan)
        if [[ "$PROCESS_FLAG" -eq 1 ]]; then
            if [[ -z "${PROCESS_DIR:-}" ]]; then
                echo "Error: No PROCESS_DIR configured. Set PROCESS_DIR in config." >&2
                exit 1
            fi
            if [[ ! -d "$PROCESS_DIR" ]]; then
                echo "Error: PROCESS_DIR '${PROCESS_DIR}' not found." >&2
                exit 1
            fi
            if ! ls "$PROCESS_DIR"/*.md &>/dev/null; then
                echo "Error: No process specs found in '${PROCESS_DIR}/'." >&2
                exit 1
            fi
            export PROCESS_DIR

            SPEC_BYTES=$(cat "$PROCESS_DIR"/*.md 2>/dev/null | wc -c)
            SPEC_COUNT=$(find "$PROCESS_DIR" -maxdepth 1 -name '*.md' | wc -l)
            SPEC_KB=$(( SPEC_BYTES / 1024 ))
            if [[ "$SPEC_KB" -lt 50 && "$SPEC_COUNT" -lt 5 ]]; then
                SPEC_VOLUME_HINT="Total process spec volume: ${SPEC_COUNT} files, ~${SPEC_KB} KB. You can likely complete planning in one iteration."
            else
                SPEC_VOLUME_HINT="Total process spec volume: ${SPEC_COUNT} files, ~${SPEC_KB} KB. This exceeds single-iteration capacity. Use the decomposition ledger and process one spec file per iteration."
            fi
            export SPEC_VOLUME_HINT

            PROMPT_TEMPLATE="$RALPH_DIR/prompts/plan-process.md"
        else
            PROMPT_TEMPLATE="$RALPH_DIR/prompts/plan.md"
        fi
        if [[ ! -f "$PROMPT_TEMPLATE" ]]; then
            echo "Error: plan prompt template not found: $PROMPT_TEMPLATE" >&2
            exit 1
        fi
        init_session_log
        run_loop "$PROMPT_TEMPLATE"
        ;;

    build)
        if [[ ! -f "$RALPH_DIR/implementation_plan.md" ]]; then
            echo "Implementation plan not found. Run 'ralph plan' first." >&2
            exit 2
        fi

        # For process plans, generate a structural task overview for prompt injection.
        # This gives the build agent an immediate view of phase order, task statuses,
        # and dependencies without reading/scrolling the full plan (which can cause
        # out-of-order task selection on large plans).
        TASK_OVERVIEW=""
        local plan_type_check
        plan_type_check=$(grep -m1 '^Plan Type:' "$RALPH_DIR/implementation_plan.md" 2>/dev/null \
            | sed 's/^Plan Type:[[:space:]]*//' || true)
        if [[ "$plan_type_check" == "process" ]]; then
            local overview
            overview=$(grep -nE '^(## Phase [0-9]|### Task [0-9]|\*?\*?Status:\*?\*?|\*?\*?Depends on:\*?\*?)' \
                "$RALPH_DIR/implementation_plan.md" 2>/dev/null || true)
            if [[ -n "$overview" ]]; then
                TASK_OVERVIEW="## Task Overview

Structural overview of phases, tasks, statuses, and dependencies extracted from the implementation plan. Use this for task selection only — you must read the full task block before implementing.

${overview}"
            fi
        fi
        export TASK_OVERVIEW

        PROMPT_TEMPLATE="$RALPH_DIR/prompts/build.md"
        if [[ ! -f "$PROMPT_TEMPLATE" ]]; then
            echo "Error: build prompt template not found: $PROMPT_TEMPLATE" >&2
            exit 1
        fi
        init_session_log
        run_loop "$PROMPT_TEMPLATE"
        ;;

    align-specs)
        if [[ -z "${PROCESS_DIR:-}" ]]; then
            echo "Error: align-specs requires process specs. Set PROCESS_DIR in config." >&2
            exit 1
        fi
        local_plan="$RALPH_DIR/implementation_plan.md"
        if [[ ! -f "$local_plan" ]]; then
            echo "Error: align-specs requires a process-type implementation plan. Run 'ralph plan --process' and 'ralph build' first." >&2
            exit 1
        fi
        local_plan_type=$(grep -m1 '^Plan Type:' "$local_plan" 2>/dev/null \
            | sed 's/^Plan Type:[[:space:]]*//' || true)
        if [[ "$local_plan_type" != "process" ]]; then
            echo "Error: align-specs requires a process-type implementation plan. Run 'ralph plan --process' and 'ralph build' first." >&2
            exit 1
        fi
        if ! grep -q 'Status:.*complete' "$local_plan" 2>/dev/null; then
            echo "Error: align-specs requires completed build work. Run 'ralph build' first." >&2
            exit 1
        fi
        export PROCESS_DIR
        PROMPT_TEMPLATE="$RALPH_DIR/prompts/align-specs.md"
        if [[ ! -f "$PROMPT_TEMPLATE" ]]; then
            echo "Error: align-specs prompt template not found: $PROMPT_TEMPLATE" >&2
            exit 1
        fi
        init_session_log
        run_loop "$PROMPT_TEMPLATE"
        ;;

    prompt)
        if [[ -z "$PROMPT_FILE" ]]; then
            echo "Error: prompt mode requires a file argument" >&2
            usage >&2
            exit 1
        fi
        if [[ ! -f "$PROMPT_FILE" ]]; then
            echo "Error: prompt file not found: $PROMPT_FILE" >&2
            exit 1
        fi
        if ! grep -qF '<promise>COMPLETE</promise>' "$PROMPT_FILE"; then
            echo "Error: prompt file must contain <promise>COMPLETE</promise>" >&2
            exit 1
        fi
        init_session_log
        run_loop "$PROMPT_FILE"
        ;;

    update)
        echo "Fetching update script from GitHub..."
        curl -sSL https://raw.githubusercontent.com/mjeffe/ralph-loop/main/update.sh | bash
        ;;

    sandbox)
        if [[ "${SANDBOX:-}" == "1" ]]; then
            echo "Error: already inside the sandbox. Run ralph commands directly." >&2
            exit 1
        fi
        sandbox_sub="${SANDBOX_ARGS[0]:-}"
        sandbox_extra=()
        [[ ${#SANDBOX_ARGS[@]} -gt 1 ]] && sandbox_extra=("${SANDBOX_ARGS[@]:1}")
        case "$sandbox_sub" in
            setup)  sandbox_setup "${sandbox_extra[@]+"${sandbox_extra[@]}"}" ;;
            up)     sandbox_up "${sandbox_extra[@]+"${sandbox_extra[@]}"}" ;;
            stop)   sandbox_stop "${sandbox_extra[@]+"${sandbox_extra[@]}"}" ;;
            reset)  sandbox_reset "${sandbox_extra[@]+"${sandbox_extra[@]}"}" ;;
            shell)  sandbox_shell "${sandbox_extra[@]+"${sandbox_extra[@]}"}" ;;
            status) sandbox_status "${sandbox_extra[@]+"${sandbox_extra[@]}"}" ;;
            *)
                echo "Usage: ralph sandbox <setup|up|stop|reset|shell|status>"
                exit 1
                ;;
        esac
        ;;

    *)
        echo "Error: unknown mode: $MODE" >&2
        usage >&2
        exit 1
        ;;
esac
